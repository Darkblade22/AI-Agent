# === Скопируй этот файл в .env и впиши свои значения ===

# Токен Telegram-бота (получить у @BotFather командой /newbot)
TELEGRAM_BOT_TOKEN=сюда_токен_бота

# API-ключ Fireworks (с https://fireworks.ai -> API Keys)
FIREWORKS_API_KEY=сюда_ключ_fireworks

# Твой Telegram user ID — чтобы бот отвечал только тебе.
# Узнать свой ID можно у бота @userinfobot (он пришлёт число).
# Можно указать несколько через запятую: 12345,67890
ALLOWED_USER_IDS=сюда_твой_id

# Модель Fireworks. По умолчанию Qwen2.5 72B.
MODEL=accounts/fireworks/models/qwen2p5-72b-instruct

# Адрес API (менять не нужно)
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
